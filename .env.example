# LendFlow Environment Variables
# Copy this to .env and fill in your values

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/lendflow

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=LendFlow <your-email@gmail.com>

CELERY_BROKER_URL=memory://
CELERY_TASK_ALWAYS_EAGER=True

FIELD_ENCRYPTION_KEY=your-encryption-key-base64
GROQ_API_KEY=
JWT_SIGNING_KEY=your-jwt-secret

CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
